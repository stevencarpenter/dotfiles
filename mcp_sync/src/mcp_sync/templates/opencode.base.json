{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://localhost:1234/v1"
      },
      "models": {
        "qwen/qwen3-coder-next": {
          "name": "qwen3-coder-next"
        },
        "nvidia/nemotron-3-super": {
          "name": "nemotron-3-super"
        }
      }
    },
    "omlx": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "oMLX (local)",
      "options": {
        "baseURL": "http://localhost:42069/v1"
      },
      "models": {
        "Qwen3.6-35B-A3B-UD-MLX-4bit": {
          "name": "Qwen3.6 35B (oMLX)"
        }
      }
    }
  },
  "permission": {
    "bash": {
      "*": "allow",
      "git push*": "ask",
      "git reset --hard*": "ask",
      "git clean -fd*": "ask",
      "git rebase*": "ask",
      "npm publish*": "ask",
      "cargo publish*": "ask",
      "sudo*": "deny",
      "rm -rf /": "deny",
      "rm -rf /*": "deny",
      "rm -rf ~": "deny",
      "rm -rf ~/*": "deny",
      "chmod 777*": "deny",
      "dd if=*": "deny",
      "mkfs.*": "deny",
      "curl * | bash": "deny",
      "curl * | sh": "deny",
      "wget * | bash": "deny",
      "wget * | sh": "deny",
      "> /dev/*": "deny"
    }
  },
  "mcp": {
    "excalidraw": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "-e",
        "EXPRESS_SERVER_URL=http://host.docker.internal:3000",
        "-e",
        "ENABLE_CANVAS_SYNC=true",
        "ghcr.io/yctimlin/mcp_excalidraw:latest"
      ],
      "enabled": true
    }
  }
}
