# Templated externals. The tpm entry is unconditional; the agent-registry
# clone is gated on the `agents` machine capability (see .chezmoidata/machines.toml).

[".config/tmux/plugins/tpm"]
    type = "git-repo"
    url = "https://github.com/tmux-plugins/tpm.git"
    refreshPeriod = "168h"  # Pull updates weekly

{{ if (index .machines .machine).agents -}}
# AI agent registry — single source of truth for custom agents. Cloned here so
# .chezmoiscripts/run_after_sync-agents.sh.tmpl can run its installer, which
# fans the canonical agents out to each tool's native format/location.
[".local/share/agent-registry"]
    type = "git-repo"
    url = "git@github.com:stevencarpenter/agents.git"
    refreshPeriod = "1h"  # Pull hourly — registry is actively curated (force now: chezmoi apply --refresh-externals)
{{- end }}
