!.claude/settings.json

# Skills under ~/.claude/skills/ are not tracked here. Skills installed by
# claude-plugins are symlinks to ~/.agents/skills/, and locally authored
# skills also live in ~/.agents/skills/ so they can be reused outside this
# repo. If a future skill ever needs to ride along with the dotfiles, add it
# back with a `!.claude/skills/<name>` un-ignore pattern.

# Work/personal/lab conditional deployment
# Skip work files on non-work machines
{{ if not (hasPrefix "work" .machine) }}
.config/aws-config-gen/overrides.json
.config/mcp/machine/work.json
.config/zsh/.work.env
.config/zsh/profile.d/work-secrets.zsh
.config/zsh/profile.d/work-shell-functions.zsh
.config/zsh/profile.d/work-aws-shell-functions.zsh
{{ end }}

# Skip personal files on non-personal machines
{{ if not (hasPrefix "personal" .machine) }}
.config/mcp/machine/personal.json
.config/zsh/.personal.env
.config/zsh/profile.d/personal-secrets.zsh
.config/zsh/profile.d/personal-shell-functions.zsh
.config/aerospace/layouts/workspace-5-comms.sh
Library/LaunchAgents/com.user.xcode-mcp-proxy.plist
{{ end }}

# Skip lab files on non-lab machines
{{ if ne .machine "lab-mac" }}
.config/mcp/machine/lab.json
.config/zsh/profile.d/lab-shell-functions.zsh
{{ end }}

{{ if ne .chezmoi.os "darwin" }}
Library/LaunchAgents/com.user.xcode-mcp-proxy.plist
{{ end }}

# xcode-mcp-proxy temporarily disabled — this is the SINGLE kill-switch.
# Remove this line (and its comment) to re-enable. The plist template + the
# load script already gate themselves on (personal-mac && darwin), so simply
# un-ignoring restores the feature on personal-mac without touching three
# files. Lines 81-89 above also gate the plist on hasPrefix "personal" —
# that gate becomes the only restriction once this line is gone.
Library/LaunchAgents/com.user.xcode-mcp-proxy.plist

# Capability gates (see .chezmoidata/machines.toml)
# Skip the tiling-WM stack (aerospace + sketchybar) on machines where it's off.
{{ if not (index .machines .machine).tiling }}
.config/aerospace
.config/sketchybar
.config/borders
{{ end }}

# Skip the atuin client config on machines that should never sync to the
# self-hosted server (e.g., work machines). Vanilla local-only atuin still
# works without this file.
{{ if not (index .machines .machine).atuin }}
.config/atuin
{{ end }}

# Skip the MCP master config + per-tool overrides on machines that don't run
# the MCP fan-out. The post-apply sync hook itself self-gates on the same
# capability, so it becomes a no-op without the source files.
{{ if not (index .machines .machine).mcp }}
.config/mcp
{{ end }}

# Skip the hippo brain client config on machines that don't run hippo
# locally. The hippo SessionStart hook in ~/.claude/settings.json is gated on
# the same capability via dot_claude/modify_settings.json.tmpl.
{{ if not (index .machines .machine).hippo }}
.config/hippo
{{ end }}
