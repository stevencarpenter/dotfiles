# Ignore non-dotfile directories and files in the repository
.git
.idea

# Ignore all claude-mem generated CLAUDE.md files (keep only root CLAUDE.md for project instructions)
**/.git/CLAUDE.md
**/.git/**/CLAUDE.md
!CLAUDE.md

.chezmoiscripts/CLAUDE.md
.chezmoiignore/**/*.md
dot_config/**/CLAUDE.md
dot_codex/CLAUDE.md
dot_claude/CLAUDE.md
scripts/CLAUDE.md
docs/**/CLAUDE.md

# Generated by mcp_sync (single-writer outputs)
.codex/config.toml
.config/opencode/opencode.json


# Ignore .claude transient data
.claude/debug
.claude/downloads
.claude/file-history
.claude/history.jsonl
.claude/ide
.claude/plans
.claude/plugins
.claude/projects
.claude/session-env
.claude/shell-snapshots
.claude/stats-cache.json
.claude/statsig
.claude/telemetry
.claude/todos
.github
.pre-commit-config.yaml
.envrc
.gitignore
README.md
CLAUDE.md
docs
scripts
private_dot_claude.json

# Ignore copilot generated garbage. Fuck you copilot, Microsoft, pedophile Bill Gates.
**/.copilot/**/*
**/.config/**/*copilot**/**

# Ignore all .DS_Store files
**/*.DS_Store

# Ignore Python bytecode
**/__pycache__/**
**/*.pyc
**/*.pyo

# Ignore claude transient data (target paths under ~/.claude/)
.claude/*
!.claude/settings.json

# Track skills authored locally. Most skills under ~/.claude/skills/ are
# symlinks to ~/.agents/skills/ (managed by claude-plugins) and shouldn't be
# checked into dotfiles — but skills authored directly belong here. Add new
# tracked skills by name; the !-prefixed pattern un-ignores the parent dir
# and its contents so chezmoi can see them.
!.claude/skills
.claude/skills/*
!.claude/skills/screenshot-bug-hunt
!.claude/skills/screenshot-bug-hunt/**

# Work/personal conditional deployment
# Skip work files on personal machines
{{ if not (hasPrefix "work" .machine) }}
.config/aws-config-gen/overrides.json
.config/mcp/machine/work.json
.config/zsh/.work.env
.config/zsh/profile.d/work-secrets.zsh
.config/zsh/profile.d/work-shell-functions.zsh
.config/zsh/profile.d/work-aws-shell-functions.zsh
{{ end }}

# Skip personal files on work machines
{{ if not (hasPrefix "personal" .machine) }}
.config/mcp/machine/personal.json
.config/zsh/.personal.env
.config/zsh/profile.d/personal-secrets.zsh
.config/zsh/profile.d/personal-shell-functions.zsh
.config/aerospace/layouts/workspace-5-comms.sh
Library/LaunchAgents/com.user.xcode-mcp-proxy.plist
{{ end }}

{{ if ne .chezmoi.os "darwin" }}
Library/LaunchAgents/com.user.xcode-mcp-proxy.plist
{{ end }}
