#!/usr/bin/env bash
# Install mcp-proxy and (re)load the xcode-mcp-proxy LaunchAgent on personal
# macOS machines. The agent supervises a single `xcrun mcpbridge` process behind
# http://127.0.0.1:9876/mcp so every MCP client shares one connection instead
# of spawning mcpbridge per session (which otherwise triggers TCC approval
# prompts on every launch).
#
# plist-hash: {{ include "Library/LaunchAgents/com.user.xcode-mcp-proxy.plist.tmpl" | sha256sum }}
set -euo pipefail

{{ if and (hasPrefix "personal" .machine) (eq .chezmoi.os "darwin") -}}

PLIST_PATH="${HOME}/Library/LaunchAgents/com.user.xcode-mcp-proxy.plist"
LABEL="com.user.xcode-mcp-proxy"
export PATH="${HOME}/.vite-plus/bin:${HOME}/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:${PATH}"

if [[ ! -f "${PLIST_PATH}" ]]; then
  echo "xcode-mcp-proxy: plist not yet deployed at ${PLIST_PATH}; skipping." >&2
  exit 0
fi

if ! command -v mcp-proxy >/dev/null 2>&1; then
  if ! command -v vp >/dev/null 2>&1; then
    echo "xcode-mcp-proxy: neither mcp-proxy nor vp on PATH; install one and re-run 'chezmoi apply'." >&2
    exit 1
  fi
  echo "xcode-mcp-proxy: installing mcp-proxy via vp..."
  vp install -g mcp-proxy
fi

mkdir -p "${HOME}/Library/Logs"

DOMAIN="gui/$(id -u)"

# Always reload so plist edits take effect. bootout may fail if the agent
# isn't currently loaded — ignore that specific case.
launchctl bootout "${DOMAIN}/${LABEL}" 2>/dev/null || true
launchctl bootstrap "${DOMAIN}" "${PLIST_PATH}"

echo "xcode-mcp-proxy: loaded (${DOMAIN}/${LABEL})."

{{ end -}}
