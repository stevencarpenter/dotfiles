[tools]
# Version policy:
# - Pin critical automation/security tools to explicit versions for reproducibility.
# - Use "latest" only for lower-risk tools where faster updates are preferred.

# Programming Languages & Runtimes (all machines)
go = "1.26"
java = "corretto-25"
node = "25"
scala = "3.8"
npm = "11"
pnpm = "11"
sbt = "1.12"
usage = "latest"
terraform = "1.14"
gradle = "9"
goreleaser = "latest"

# LSP servers (backing binaries for the Claude Code *-lsp plugins; the plugins are
# integration shims only — the servers must resolve on $PATH). All-machines set
# matches the always-enabled plugins: pyright-lsp, gopls-lsp, rust-analyzer-lsp.
"npm:pyright" = "latest"                  # pyright-langserver (Python)
"go:golang.org/x/tools/gopls" = "latest"  # gopls (Go)
rust-analyzer = "latest"                  # rust-analyzer (Rust)

# Neovim tooling — nvim-treesitter requires the tree-sitter CLI on $PATH to
# compile parsers (Mason is disabled for it). All machines, since nvim deploys
# everywhere.
tree-sitter = "latest"
{{- if (index .machines .machine).dev }}

# LSP servers for dev machines — matches the dev-gated plugins typescript-lsp and
# lua-lsp (swift-lsp's sourcekit-lsp ships with Xcode, so no install needed here).
"npm:typescript-language-server" = "latest"
"npm:typescript" = "latest"               # tsserver — required by typescript-language-server
lua-language-server = "latest"
{{- end }}
{{- if (index .machines .machine).infra }}

# Infrastructure Tools (machines with infra capability)
helm = "3"
k9s = "latest"
kubectl = "1.35"
kustomize = "latest"
teleport-ent = "16"

# Databases (work machines only)
mysql = "8"
{{- end }}

# DuckDB — needed by yazi on every machine for tabular file previews
duckdb = "latest"
