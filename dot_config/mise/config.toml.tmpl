[tools]
# Version policy:
# - Pin critical automation/security tools to explicit versions for reproducibility.
# - Use "latest" only for lower-risk tools where faster updates are preferred.

# Programming Languages & Runtimes (all machines)
go = "1.26"
java = "corretto-25"
node = "25"
scala = "3.8"
npm = "11"
pnpm = "11"
sbt = "1.12"
usage = "latest"
terraform = "1.14"
gradle = "9"
goreleaser = "latest"

{{ if (index .machines .machine).infra }}
# Infrastructure Tools (machines with infra capability)
helm = "3"
k9s = "latest"
kubectl = "1.35"
kustomize = "latest"
teleport-ent = "16"

# Databases (work machines only)
mysql = "8"
duckdb = "latest"
{{ end }}
