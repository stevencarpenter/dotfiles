# === 7. Functions ===
# Simple utility functions

# Get complete command output with header and exit code, copied to clipboard (for easy sharing in chat, etc.)
function c() {
  emulate -L zsh
  setopt pipefail

  if (( $# == 0 )); then
    echo "Usage: c <command> [args...]" >&2
    return 2
  fi

  local tmpfile
  tmpfile="$(mktemp -t zshcap.XXXXXX)" || return 1

  local cmd="$*"
  local cwd="${PWD/#$HOME/~}"

  # Run command; capture stdout+stderr; still show live output
  "$@" 2>&1 | tee "$tmpfile"
  local rc=${pipestatus[1]}  # exit code of the command (not tee)

  # Copy Slack-safe text (no Nerd Font glyphs)
  {
    print -r -- "$cwd$ $cmd"
    cat "$tmpfile"
  } | pbcopy

  rm -f "$tmpfile"
  return $rc
}

function md() {
  if (( $# != 1 )); then
    echo "Usage: md <directory>" >&2
    return 2
  fi
  mkdir -p -- "$1" && cd -- "$1"
}

# Git "whoops" function: create a new branch at the current HEAD, then reset the current branch back one commit.
# Useful for quickly undoing a mistaken commit while preserving the changes in a new branch.
function goops() {
  if (( $# != 1 )); then
    echo "Usage: goops <new-branch-name>" >&2
    return 2
  fi
  git branch "$1" && git reset --hard HEAD~1 && git checkout "$1"
}

# Copy a file to the clipboard and also save it to disk (for easy sharing of files in chat, etc.)
function copyfile() {
  if ! tee "$1" >(pbcopy); then
    echo "Error: Failed to write file or copy to clipboard" >&2
    return 1
  fi
}

# Wrappers for LLM CLI tools that run the command, then run a token audit on the session afterward.
# The audit looks for provider-specific environment variables and CLI args to determine which provider to audit for.
# The audit tool is configured to look for sessions started in the current working directory, so the wrapper
# can optionally pass the CWD to the auditor if the tool being wrapped does not have a --cwd option itself (e.g. Claude).
function _run_with_token_audit() {
  local wrapper_name="$1"
  local command_name="$2"
  local provider="$3"
  local use_cwd="$4"
  shift 4

  local token_auditor_project="$HOME/.local/share/chezmoi/token_auditor"
  command "$command_name" "$@"
  local command_rc=$?

  if [[ -d "$token_auditor_project" ]]; then
    local -a audit_cmd=(
      uv run --project "$token_auditor_project"
      token-auditor --provider "$provider"
    )
    if [[ "$use_cwd" == "1" ]]; then
      audit_cmd+=(--cwd "$PWD")
    fi
    "${audit_cmd[@]}" || echo "${wrapper_name}: failed to print session usage audit" >&2
  else
    echo "${wrapper_name}: project not found at $token_auditor_project" >&2
  fi

  return $command_rc
}

# Wrappers for specific tools. The provider and whether to pass the CWD to the auditor are configured based on the tool's characteristics and typical usage patterns.
function codax() { _run_with_token_audit codax codex codex 0 "$@"; }
function claade() { _run_with_token_audit claade claude claude 1 "$@"; }
function opencade() { _run_with_token_audit opencade opencode opencode 1 "$@"; }

# Chezmoi apply with intelligent conflict resolution.
# - Applies manual changes from source
# - Preserves target-side changes that differ from source
# - Shows what would be applied before doing so
function ca() {
  echo "Checking for conflicts between source and target..."

  # Show what would be applied
  echo "Changes to be applied:"
  chezmoi diff --exclude=scripts

  # Check if there are any conflicts (target differs from expected source)
  # Look for actual file deletions/changes, not diff headers
  if chezmoi diff --exclude=scripts | grep -q "^-[^-]"; then
    echo ""
    echo "   Target files have changes that differ from source."
    echo "   These will be preserved. Only source changes will be applied."
    echo ""
    read -q "continue?Proceed with applying source changes? [y/N] " || return 1
    echo ""
    [[ "$continue" != "y" ]] && return 1
  fi

  echo "Applying changes..."
  chezmoi apply "$@"
  echo "Done!"
}

# Yazi TUI file manager wrapper (updates shell CWD on exit)
function y() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
	command yazi "$@" --cwd-file="$tmp"
	IFS= read -r -d '' cwd < "$tmp"
	[ "$cwd" != "$PWD" ] && [ -d "$cwd" ] && builtin cd -- "$cwd"
	rm -f -- "$tmp"
}

# === 8. Tool Initializations (after PATH is set) ===
# These tools need to be initialized after PATH is configured

# zoxide (smart cd)
eval "$(zoxide init --cmd cd zsh)"

# mise (polyglot runtime manager) - lazy load with hook prevention
if command -v mise >/dev/null 2>&1; then
  # Add shims to PATH
  path=($HOME/.local/share/mise/shims $path)

  # Prevent mise hooks during startup
  unset -f _mise_hook 2>/dev/null || true

  # Create wrapper function that activates on first use
  mise() {
    if [[ -z "${MISE_SHELL-}" ]]; then
      eval "$(~/.local/bin/mise activate zsh --shims-as-is)"
      # Remove this wrapper after activation
      unfunction mise 2>/dev/null || true
    fi
    command mise "$@"
  }
fi

# atuin (shell history)
[[ -f "$HOME/.local/bin/env" ]] && . "$HOME/.local/bin/env" || true
[[ -f "$HOME/.atuin/bin/env" ]] && . "$HOME/.atuin/bin/env" || true
eval "$(atuin init zsh)"

# tv (terminal visualizer shell completions) - lazy load
_tv_lazy_init() {
  if command -v tv >/dev/null 2>&1; then
    eval "$(tv init zsh)"
    add-zsh-hook -d precmd _tv_lazy_init 2>/dev/null || true
  fi
}
if command -v tv >/dev/null 2>&1; then
  autoload -Uz add-zsh-hook
  add-zsh-hook precmd _tv_lazy_init
fi

# === 9. Completions ===
# Lazy load completions to speed up startup - defer until first command
# Add Homebrew completions to fpath BEFORE compinit runs
fpath+=$(brew --prefix)/share/zsh/site-functions

_zsh_lazy_load_completions() {
  # Remove the hook so this only runs once
  add-zsh-hook -d precmd _zsh_lazy_load_completions 2>/dev/null || true

  # Now load completions
  autoload -Uz +X compinit && compinit
  autoload -Uz +X bashcompinit && bashcompinit

  # Set up completions for custom functions
  compdef _directories md
  if command -v aws-sso >/dev/null 2>&1; then
    compdef __aws_sso_profile_complete aws-sso-profile
    complete -C /opt/homebrew/bin/aws-sso aws-sso
  fi
}

# Hook into precmd to load completions after first prompt, but only if not already loaded
if ! typeset -f compinit >/dev/null; then
  autoload -Uz add-zsh-hook
  add-zsh-hook precmd _zsh_lazy_load_completions
fi

