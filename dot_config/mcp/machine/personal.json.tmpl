{
  "$schema": "https://modelcontextprotocol.io/schema/config.json",
  "servers": {
    "hippo": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--project",
        "{{ .chezmoi.homeDir }}/projects/hippo/brain",
        "hippo-mcp"
      ],
      "autoApprove": ["ask", "search_knowledge", "search_events", "get_entities"]
    },
    "grafana": {
      "type": "stdio",
      "command": "uvx",
      "args": ["mcp-grafana@0.15.2", "--disable-write"],
      "env": {
        "GRAFANA_URL": "http://localhost:3000"
      }
    },
    "codegraph": {
      "type": "stdio",
      "command": "codegraph",
      "args": ["serve", "--mcp"]
    }
  }
}
