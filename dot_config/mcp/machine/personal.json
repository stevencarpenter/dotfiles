{
  "$schema": "https://modelcontextprotocol.io/schema/config.json",
  "servers": {
    "hippo": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--project",
        "/Users/carpenter/projects/hippo/brain",
        "hippo-mcp"
      ],
      "autoApprove": ["ask", "search_knowledge", "search_events", "get_entities"]
    },
    "grafana": {
      "type": "stdio",
      "command": "uvx",
      "args": ["mcp-grafana", "--disable-write"],
      "env": {
        "GRAFANA_URL": "http://localhost:3000"
      }
    },
    "railway-mcp-server": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@railway/mcp-server"
      ]
    },
    "xcode": {
      "type": "http",
      "url": "http://localhost:9876/mcp"
    }
  }
}
