# Homebrew Bundle for macOS
# Rendered by chezmoi to `~/.config/homebrew/Brewfile`; use `brew bundle --global` or set
# `HOMEBREW_BUNDLE_FILE=~/.config/homebrew/Brewfile` when invoking commands.

cask_args appdir: "/Applications"

# ============================================================================
# Shell & Core
# ============================================================================
brew "zsh"
brew "zsh-completions"
brew "bash"
brew "bash-completion"

# ============================================================================
# CLI Tools
# ============================================================================
brew "age"                    # Encryption tool (for chezmoi)
brew "bat"                    # Syntax-highlighting cat replacement
brew "brotli"
brew "chezmoi"                # Dotfile manager
brew "curl"
brew "fd"                     # Fast find alternative
brew "fzf"                    # Fuzzy finder
brew "grex"                   # Regex generator
brew "htop"                   # Process viewer
brew "jq"                     # JSON processor
brew "make"
brew "ripgrep"                # Fast grep (rg)
brew "tree"
brew "watch"
brew "wget"
brew "xz"
brew "eza"                    # Modern ls replacement
brew "yazi"                   # TUI file manager
brew "yq"                     # YAML processor
brew "zoxide"                 # Smart cd
brew "btop"
brew "ffmpeg"
brew "neovim"
brew "uv"
brew "mactop"
brew "worktrunk"
brew "cloc"

# ============================================================================
# Git & Version Control
# ============================================================================
brew "git"
brew "git-extras"
brew "git-secrets"
brew "git-delta"
brew "gh"
brew "lazydocker"
brew "lazygit"

# ============================================================================
# Development
# ============================================================================
brew "docker-completion"
brew "gnu-sed"
brew "shellcheck"
brew "tmux"

# ============================================================================
# Window Management & Status Bar
# ============================================================================
tap "nikitabobko/tap"
tap "FelixKratz/formulae"
cask "nikitabobko/tap/aerospace" # Tiling window manager
brew "sketchybar"                # Custom macOS status bar
brew "borders"                   # Focused-window borders (JankyBorders)

# ============================================================================
# GUI Applications
# ============================================================================
cask "alt-tab"                # Window switcher
cask "ghostty"                # Terminal emulator
cask "raycast"                # Launcher
cask "visual-studio-code"
cask "1password"
cask "1password-cli"
cask "bbedit"
cask "obsidian"
cask "orbstack"               # Docker/Linux VMs
cask "the-unarchiver"
cask "codex"

# ============================================================================
# Fonts (nerd fonts needed by Powerlevel10k + extras)
# Powerlevel10k is configured to require Nerd Font icons (see dot_config/zsh/dot_p10k.zsh).
cask "font-meslo-for-powerlevel10k"
cask "font-meslo-lg-nerd-font"
cask "font-symbols-only-nerd-font"
cask "font-jetbrains-mono-nerd-font"
cask "font-jetbrains-mono"
cask "font-sketchybar-app-font"

{{ if hasPrefix "personal" .machine }}
# ============================================================================
# Personal-only tooling
# ============================================================================
brew "railway"                   # Railway CLI
cask "font-anonymous-pro"
cask "font-bebas-neue"
cask "font-courier-prime"
cask "font-fira-code"
cask "font-ia-writer-duo"
cask "font-ia-writer-mono"
cask "font-ia-writer-quattro"
cask "font-inconsolata"
cask "font-input"
cask "font-intel-one-mono"
cask "font-iosevka"
cask "font-liberation"
cask "font-red-hat-mono"
cask "font-ubuntu-mono"
cask "font-victor-mono"
cask "font-dejavu-sans-mono-nerd-font"
cask "font-inconsolata-go-nerd-font"

{{ end }}

{{ if hasPrefix "work" .machine }}
# ============================================================================
# Work-only tooling
# ============================================================================
brew "aws-sso-cli"
brew "conftest"               # Policy testing
{{ end }}
