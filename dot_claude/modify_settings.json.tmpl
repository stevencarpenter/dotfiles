#!/usr/bin/env bash
# Manages ~/.claude/settings.json idempotently.
#
# Reads the existing target from stdin and recursively merges the chezmoi-managed
# config on top. Keys NOT defined in $managed (e.g. model, effortLevel, editorMode)
# are preserved from the live file so Claude Code's in-tool changes survive apply.
# Output is sorted (jq -S) for deterministic diffs.

set -euo pipefail

{{- $personal := hasPrefix "personal" .machine -}}
{{- $work := hasPrefix "work" .machine }}

managed=$(cat <<'JSON'
{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "ENABLE_LSP_TOOL": "1",
    "CLAUDE_CODE_FORK_SUBAGENTS": "1"
  },
  "permissions": {
    "defaultMode": "auto"
  },
{{- if $personal }}
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.local/share/hippo-brain/shell/claude-session-hook.sh"
          }
        ]
      }
    ]
  },
{{- end }}
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "atlassian@claude-plugins-official": {{ $work }},
    "claude-code-setup@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "cloudflare@cloudflare": {{ $personal }},
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": {{ $personal }},
    "commit-commands@claude-plugins-official": {{ $personal }},
    "context7@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": {{ $personal }},
    "frontend-design@claude-plugins-official": {{ $personal }},
    "github@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "hookify@claude-plugins-official": {{ $personal }},
    "lua-lsp@claude-plugins-official": {{ $personal }},
    "playwright@claude-plugins-official": {{ $personal }},
    "pyright-lsp@claude-plugins-official": true,
    "railway@claude-plugins-official": {{ $personal }},
    "ralph-loop@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "semgrep@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": {{ $personal }},
    "superpowers@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": {{ $personal }},
    "typescript-lsp@claude-plugins-official": {{ $personal }}
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "cloudflare": {
      "source": {
        "source": "github",
        "repo": "cloudflare/skills"
      }
    }
  },
  "autoDreamEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true,
  "teammateMode": "tmux"
}
JSON
)

existing=$(cat)
[[ -z "$existing" ]] && existing='{}'

printf '%s\n' "$existing" | jq -S --argjson managed "$managed" '. * $managed'
