{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "ENABLE_LSP_TOOL": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": false,
    "superpowers@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": false,
    "playwright@claude-plugins-official": false,
    "commit-commands@claude-plugins-official": false,
    "claude-md-management@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": false,
    "claude-code-setup@claude-plugins-official": true,
    "hookify@claude-plugins-official": false,
    "railway@claude-plugins-official": false,
    "cloudflare@cloudflare": false,
    "swift-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": false,
    "pyright-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": false,
    "atlassian@claude-plugins-official": false,
    "feature-dev@claude-plugins-official": false,
    "ralph-loop@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "cloudflare": {
      "source": {
        "source": "github",
        "repo": "cloudflare/skills"
      }
    }
}{{- if hasPrefix "personal" .machine }},
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/carpenter/projects/hippo/shell/claude-session-hook.sh"
          }
        ]
      }
    ]
  }
{{- end}},
  "effortLevel": "high",
  "voiceEnabled": true,
  "autoDreamEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "teammateMode": "auto"
}
